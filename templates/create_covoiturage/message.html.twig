{% extends'base.html.twig' %}

{% block body %}

    {% for convo in conversations %}
        <div class="p-4 mb-3 bg-gray-100 rounded">
            <p class="text-sm text-gray-600">
                Conversation avec Utilisateur <strong>{{ convo.interlocuteur.username }}</strong><br>
                Offre : {{ convo.offre.TitreSpectacle }}
            </p>
            <a href="#"
               class="text-indigo-600 hover:underline text-sm">
                Voir la conversation
            </a>
        </div>
    {% endfor %}
{% endblock %}