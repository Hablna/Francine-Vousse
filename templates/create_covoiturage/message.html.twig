{% extends'base.html.twig' %}

{% block body %}

<div class="flex h-screen bg-gray-100">
    <!-- ✅ Colonne de gauche : conversations -->
    <div class="w-1/3 p-4 bg-white shadow-lg overflow-y-auto border-r">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Conversations</h2>

        <ul class="space-y-3">
            {% if conversations is defined %}
                {% for convo in conversations %}
                    <li>
                        <a href="{{ path('app_message_conversation', {
                            'offreId': convo.offre.id,
                            'interlocuteurId': convo.interlocuteur.id
                        }) }}"
                           class="block p-3 rounded-lg transition 'bg-indigo-100 font-semibold' : 'hover:bg-gray-100'">
                            <div class="text-sm text-gray-800">Offre : {{ convo.offre.titreSpectacle }}</div>
                            <div class="text-xs text-gray-500">Avec : Utilisateur {{ convo.interlocuteur.username }}</div>
                        </a>
                    </li>
                {% endfor %}
            {% endif %}
        </ul>
    </div>

    <!-- ✅ Colonne de droite : messages -->
    <div class="w-2/3 p-6 flex flex-col">
        <div class="flex-1 overflow-y-auto space-y-4 bg-gray-50 p-4 rounded-lg shadow-inner">
            {% if messages is defined %}
                {% for message in messages %}
                    <div class="flex {{ message.expediteur.id == app.user.id ? 'justify-end' : 'justify-start' }}">
                        <div class="{{ message.expediteur.id == app.user.id ? 'bg-indigo-100' : 'bg-white' }} px-4 py-3 rounded-lg max-w-md shadow">
                            <p class="text-sm text-gray-800">{{ message.contenu }}</p>
                            <p class="text-xs text-gray-500 mt-1">{{ message.envoyeLe|date('d/m/Y H:i') }}</p>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <p class="text-gray-500 text-sm">Sélectionnez une conversation pour voir les messages.</p>
            {% endif %}
        </div>
    </div>
</div>

{% endblock %}