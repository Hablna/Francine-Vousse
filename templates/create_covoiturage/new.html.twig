{% extends 'base.html.twig' %}

{% block title %}offre{% endblock %}
{% block body %}

    {% include'partials/_header.html.twig' %}

    <div class="max-w-2xl mx-auto mt-32 p-6 bg-white shadow-lg rounded-2xl">
    <h1 class="text-2xl font-bold mb-6 text-gray-800">Créer une offre</h1>
    {% if app.session.flashBag.has('error') %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mt-4 mx-auto max-w-md"
             role="alert">
            <strong class="font-bold">Erreur!</strong>
            <span class="block sm:inline">{{ app.session.flashBag.get('error')[0] }}</span>
        </div>
    {% endif %}

    {{ form_start(form) }}

    <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-1">Type d'accompagnement</label>
        {{ form_widget(form.Type, { 'attr': {'class': 'w-full px-4 py-2 border rounded-lg text-gray-800'} }) }}
    </div>

    <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-1">Point de départ</label>
        {{ form_widget(form.pointDepart, { 'attr': {'class': 'w-full px-4 py-2 border rounded-lg text-gray-800'} }) }}
    </div>

    <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-1">Description</label>
        {{ form_widget(form.Description, { 'attr': {'class': 'w-full px-4 py-2 border rounded-lg text-gray-800', 'rows': '4'} }) }}
    </div>

    <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-1">Numéro de billet</label>
        {{ form_widget(form.numeroBillet, { 'attr': {'class': 'w-full px-4 py-2 border rounded-lg text-gray-800', 'type': 'number'} }) }}
    </div>

    <div class="mb-6">
        <label for="horaire" class="block text-gray-700 font-semibold mb-1">Lieux et Horaires du spectacle</label>
        <select name="horaire" id="horaire" required
                class="w-full px-4 py-2 border rounded-lg text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option disabled selected value="">-- Choisir un horaire --</option>
            {% for planif in planifications %}
                <option value="{{ planif.dateSpectacle }}">
                    {{ planif.lieu }} - {{ planif.dateSpectacle|date('d,m,Y H:i')}}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="text-right">
        <button type="submit"
                class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition duration-200">
            Publier l'offre
        </button>
    </div>

    {{ form_end(form) }}
{% endblock %}