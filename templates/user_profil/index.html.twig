{% extends 'base.html.twig' %}

{% block title %}Hello UserProfilController!{% endblock %}

{% block body %}

    {% include 'partials/_header.html.twig' %}
    <div class="bg-gray-100 mt-16">
        <div class="container mx-auto py-8">
            <div class="grid grid-cols-4 sm:grid-cols-12 gap-6 px-4">
                <div class="col-span-4 sm:col-span-3">
                    <div class="bg-white shadow rounded-lg p-6">
                        <div class="flex flex-col items-center">
                            {% if app.user.profilePicture %}
                                <img src="{{ asset('uploads/'~app.user.profilePicture) }}" class="w-32 h-32 bg-gray-300 rounded-full mb-4 shrink-0">
                            {% else %}
                                <img src="{{ asset('images/user.png') }}" class="w-32 h-32 bg-gray-300 rounded-full mb-4 shrink-0">
                            {% endif %}

                            <h1 class="text-xl ">{{ app.user.civility }} <strong>{{ app.user.prenom }}</strong> {{ app.user.name }}</h1>
                            <p class="text-gray-700">{{ app.user.username }}</p>
                            <div class="mt-6 flex flex-wrap gap-4 justify-center">
                                <a href="#" class="bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded">Contact</a>
                                <a href="#" class="bg-gray-300 hover:bg-gray-400 text-gray-700 py-2 px-4 rounded">Resume</a>
                            </div>
                        </div>
                        <hr class="my-6 border-t border-gray-300">

                    </div>
                </div>

                <!-- Onglets -->
                <div class="col-span-9">
                    <div class="mb-6 border-b border-gray-200">
                        <ul class="flex flex-wrap text-sm font-medium text-center text-gray-500">
                            <li class="me-2">
                                <button onclick="openTab(event, 'historique-tab')" id="default-tab"
                                        class="inline-block px-4 py-2 text-white bg-blue-600 rounded-t-lg">Historique</button>
                            </li>
                            <li class="me-2">
                                <button onclick="openTab(event, 'parametres-tab')"
                                        class="inline-block px-4 py-2 rounded-t-lg hover:bg-gray-100">Paramètres</button>
                            </li>
                        </ul>
                    </div>

                    <!-- historique -->
                    <div class="col-span-4 sm:col-span-9 tab-content" id="historique-tab">
                        <div class="bg-white shadow rounded-lg p-6">

                            <h2 class="text-xl font-semibold text-center mt-3 -mb-2">
                                Historiques de covoiturage
                            </h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                                <!-- Colonne : Effectués -->
                                <div class="flex flex-col items-center">
                                    <h3 class="font-bold mt-6 mb-4">Covoiturages effectués</h3>
                                    <div class="mb-6 ">
                                        {% if offresPassees is empty %}
                                            <p class="text-gray-500">Aucun covoiturage effectué.</p>
                                        {% endif %}
                                        {% for past in offresPassees %}
                                            <span class="text-gray-700 font-bold">{{ past.TitreSpectacle }}</span>

                                            <p class="mt-2">
                                                <strong>Date</strong>: {{ past.horaire|date('d/m/Y H:i') }}<br>
                                            </p>
                                        {% endfor %}
                                    </div>
                                </div>
                                <!--<div class="w-px bg-gray-300 h-full"></div>-->

                                <!-- Colonne : À venir -->
                                <div class="flex flex-col items-center">
                                    <h3 class="font-bold mt-6 mb-4">Covoiturages à venir</h3>
                                    <div class="mb-6 ">
                                        {% if offresFutures is empty %}
                                            <p class="text-gray-500">Aucun covoiturage à venir.</p>
                                        {% endif %}
                                        {% for past in offresFutures %}
                                            <li><span class="text-gray-700 font-bold">{{ past.TitreSpectacle }}</span></li>

                                            <p class="mt-2">
                                                <strong>Date</strong>: {{ past.horaire|date('d/m/Y H:i') }}<br>
                                            </p>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Paramètres -->
                    <div id="parametres-tab" class="hidden tab-content col-span-4 sm:col-span-9">
                        <div class="bg-white shadow rounded-lg p-6">
                            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                            <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">

                                <!-- civilité -->
                                <div>
                                    {{ form_label(form.civility, 'Civility', {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900'}}) }}
                                    <div class="border-1 border-black-300 rounded-md p-0">
                                        {{ form_widget(form.civility, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6'}}) }}
                                    </div>
                                </div>

                                <!-- prenom -->
                                <div>
                                    {{ form_label(form.prenom, 'First Name', {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900'}}) }}
                                    <div class="border-1 border-black-300 rounded-md p-0">
                                        {{ form_widget(form.prenom, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6'}}) }}
                                    </div>
                                </div>


                                <div>
                                    {{ form_label(form.name, 'Last Name', {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900'}}) }}
                                    <div class="border-1 border-black-300 rounded-md p-0">
                                        {{ form_widget(form.name, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6'}}) }}
                                    </div>
                                </div>
                            </div>


                            <div class="form-group">
                                {{ form_label(form.username, null, {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900'}}) }}
                                <div class="border-1 border-black-300 rounded-md p-0">
                                    {{ form_widget(form.username, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6'}}) }}
                                </div>
                            </div>

                            <!-- email-->
                            <div class="form-group">
                                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900'}}) }}
                                <div class="border-1 border-black-300 rounded-md p-0">
                                    {{ form_widget(form.email, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6'}}) }}
                                </div>
                            </div>


                            <div>
                                <button type="submit" class="flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">Register</button>
                            </div>
                            {{ form_end(form) }}

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% include 'partials/_footer.html.twig' %}
    <script>
        function openTab(evt, tabId) {
            const contents = document.querySelectorAll('.tab-content');
            const tabs = evt.currentTarget.parentElement.parentElement.querySelectorAll('button');

            contents.forEach(c => c.classList.add('hidden'));
            tabs.forEach(t => t.classList.remove('bg-blue-600', 'text-white'));

            document.getElementById(tabId).classList.remove('hidden');
            evt.currentTarget.classList.add('bg-blue-600', 'text-white');
        }

        // Onglet par défaut au chargement
        window.addEventListener('DOMContentLoaded', () => {
            document.getElementById("default-tab").click();
        });
    </script>

{% endblock %}
