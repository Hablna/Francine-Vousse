{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
    {% include'partials/_header.html.twig' %}

    <!-- Hero Section -->
    <section class="bg-gradient-to-r mt-10 from-blue-500 to-indigo-600 text-white py-16 px-6 text-center ">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-4xl font-bold mb-4">Bienvenue sur notre plateforme Francine Vousse !</h1>
            <p class="text-xl mb-8">Ce site vous permet de proposer ou de rejoindre des offres de covoiturage ou de copiétonnage à l'occasion d'événements culturels. </p>
        </div>
    </section>

    <!-- Services Section -->
    <section id="offre" class="py-16 px-6">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-semibold mb-12">Les offres d'accompagnements</h2>
            <!-- message de succès -->
            {% if app.session.flashBag.has('success') %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mt-4 mx-auto max-w-md"
                     role="alert">
                    <strong class="font-bold">Succès!</strong>
                    <span class="block sm:inline">{{ app.session.flashBag.get('success')[0] }}</span>
                </div>
            {% endif %}
            <div class="grid md:grid-cols-3 gap-8">
               <!-- Affichage des offres -->
                {% for offre in offres %}
                    <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition">
                        <h3 class="text-xl font-semibold mb-4">{{ offre.TitreSpectacle }}</h3>
                        <div class="mt-6 mb-4 flex flex-wrap gap-4 justify-center">
                            <p>Date : {{ offre.horaire|date('d/m/Y H:i') }} </p>
                            <p>Depart : <strong>{{ offre.pointDepart }}</strong></p>
                        </div>
                        <p><a href="{{ path('app_message', {
                            'offreId': offre.id,
                            }) }}" class="bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded"> Contacter</a></p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>


    <!-- Contact Section -->
    <section id="contact" class="py-16 px-6 bg-blue-600 text-white text-center">
        <h2 class="text-3xl font-semibold mb-4">Contactez-Nous</h2>
        <p class="text-xl mb-8">Si vous avez des questions ou si vous souhaitez en savoir plus sur nos services,
            contactez-nous dès aujourd'hui.</p>
        <a href="mailto:h.halirounamanou@ecoles-epsi.net"
           class="bg-white text-blue-600 py-2 px-6 rounded-full font-semibold hover:bg-gray-100 transition">Envoyer un
            Email</a>
    </section>

    <!-- Footer -->
    {% include 'partials/_footer.html.twig'%}
{% endblock %}
