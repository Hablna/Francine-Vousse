{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
    {% include'partials/_header.html.twig' %}
    <header class="bg-opacity-50 backdrop-blur-lg bg-blue-600 text-white w-full z-10 fixed top-0">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex shrink-0 items-center">
                <img src="{{ asset ('images/logo.png') }}" alt="logo" class="h-10 w-auto">
            </div>

            <nav class="space-x-4">
                <a href="#offre" class="hover:text-gray-300">Offres d'accompagnements</a>
                <a href="#annonce" class="hover:text-gray-300">Créer une annonce</a>
            </nav>
            <div class="relative inline-block text-left">
                <div>
                    <img src="{{ asset('images/user.png') }}" alt="user" class="h-8 w-auto cursor-pointer" id="profile-logo">
                </div>
                <div id="dropdown-menu" class="hidden origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none">
                    <div class="py-1" role="menu" aria-orientation="vertical" aria-labelledby="options-menu">
                        {% if app.user %}
                            <a href="{{ path('app_account') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">Aperçu du compte</a>
                            <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">Se déconnecter</a>
                        {% else %}
                            <a href="{{ path('app_register') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">S'inscrire</a>
                            <a href="{{ path('app_login') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">Se connecter</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="bg-gradient-to-r mt-10 from-blue-500 to-indigo-600 text-white py-16 px-6 text-center ">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-4xl font-bold mb-4">Bienvenue sur notre site web</h1>
            <p class="text-xl mb-8">Ici, les offres de covoiturage et de copiétonnage </p>
        </div>
    </section>

    <!-- Services Section -->
    <section id="offre" class="py-16 px-6">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-semibold mb-12">Les offres d'accompagnements</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Service 1 -->
                <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition">
                    <h3 class="text-xl font-semibold mb-4">spectacle 1</h3>
                    <p>ce spectacle nananiii nananaaa.</p>
                </div>
                <!-- Service 2 -->
                <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition">
                    <h3 class="text-xl font-semibold mb-4">spectacle 2</h3>
                    <p>ce spectacle nananiii nananaaa.</p>
                </div>
                <!-- Service 3 -->
                <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition">
                    <h3 class="text-xl font-semibold mb-4">Spectacle 3</h3>
                    <p>ce spectacle nananiii nananaaa.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- section annonce -->
    <section id="annonce" class="bg-gray-50 py-16 px-6">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-3xl font-semibold mb-6">Annonce</h2>
            <p class="text-xl max-w-3xl mx-auto mb-8">Francisse Vasse est imaginaire</p>
            <a href="#contact"
               class="bg-blue-600 text-white py-2 px-6 rounded-full font-semibold hover:bg-blue-700 transition">Nous
                Contacter</a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-16 px-6 bg-blue-600 text-white text-center">
        <h2 class="text-3xl font-semibold mb-4">Contactez-Nous</h2>
        <p class="text-xl mb-8">Si vous avez des questions ou si vous souhaitez en savoir plus sur nos services,
            contactez-nous dès aujourd'hui.</p>
        <a href="mailto:contact@monsite.com"
           class="bg-white text-blue-600 py-2 px-6 rounded-full font-semibold hover:bg-gray-100 transition">Envoyer un
            Email</a>
    </section>

    <!-- Footer -->
    {% include'partials/_footer.html.twig' %}

    <script>
        document.getElementById('profile-logo').addEventListener('click', function() {
            var dropdownMenu = document.getElementById('dropdown-menu');
            dropdownMenu.classList.toggle('hidden');
        });

        document.addEventListener('click', function(event) {
            var isClickInside = document.getElementById('profile-logo').contains(event.target) || document.getElementById('dropdown-menu').contains(event.target);
            if (!isClickInside) {
                document.getElementById('dropdown-menu').classList.add('hidden');
            }
        });
    </script>
{% endblock %}
